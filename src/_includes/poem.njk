---
layout: base.njk
---

<article>
  <header class="poem-header">
    <h1 class="poem-title">{{ title }}</h1>
    <time class="poem-date" datetime="{{ page.date | isoDate }}">
      {{ page.date | readableDate }}
    </time>
  </header>

  <hr class="poem-divider" />

  <div class="poem-body">
    {{ content | safe }}
  </div>
</article>

{% set poemSlug = page.fileSlug %}
{% set poemComments = comments[poemSlug] %}

<section class="comments-section">
  <div class="comments-header">
    <hr class="comments-divider" />
    <h2 class="comments-title">Reflections</h2>
  </div>

  <ul class="comment-list" id="comment-list">
    {% if poemComments and poemComments.length %}
      {% for c in poemComments %}
        <li class="comment-item">
          <blockquote class="comment-text">{{ c.text }}</blockquote>
          <footer class="comment-meta">
            <span class="comment-name">&mdash; {{ c.name }}</span>
            <time class="comment-date">{{ c.date | readableDate }}</time>
          </footer>
        </li>
      {% endfor %}
    {% else %}
      <p class="comments-empty" id="comments-empty">Be the first to leave a reflection.</p>
    {% endif %}
  </ul>

  <form class="comment-form" id="comment-form" data-slug="{{ poemSlug }}">
    <div class="comment-form-fields">
      <input
        type="text"
        name="comment-name"
        class="comment-input"
        placeholder="Your name"
        autocomplete="off"
        required
      />
      <textarea
        name="comment-text"
        class="comment-textarea"
        placeholder="Leave a reflection&hellip;"
        rows="3"
        required
      ></textarea>
    </div>
    <div class="comment-form-footer">
      <button type="submit" class="comment-submit">post</button>
    </div>
  </form>
</section>

{% set poems = collections.poems %}
{% set currentIndex = 0 %}
{% for poem in poems %}
  {% if poem.url == page.url %}
    {% set currentIndex = loop.index0 %}
  {% endif %}
{% endfor %}

{% set prevPoem = poems[currentIndex + 1] %}
{% set nextPoem = poems[currentIndex - 1] if currentIndex > 0 else null %}

<nav class="poem-nav">
  <div>
    {% if prevPoem %}
      <a href="{{ prevPoem.url | url }}" class="poem-nav-link">
        &larr; earlier
        <span class="poem-nav-label">{{ prevPoem.data.title }}</span>
      </a>
    {% endif %}
  </div>
  <div>
    {% if nextPoem %}
      <a href="{{ nextPoem.url | url }}" class="poem-nav-link" style="text-align:right;">
        later &rarr;
        <span class="poem-nav-label">{{ nextPoem.data.title }}</span>
      </a>
    {% endif %}
  </div>
</nav>

<a href="{{ '/' | url }}" class="poem-nav-back">&uarr; all poems</a>
