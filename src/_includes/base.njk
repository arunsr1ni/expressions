<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or 'A poetry blog — Expressions of an Analog Soul' }}" />
  <title>{% if title %}{{ title }} — {% endif %}Expressions of an Analog Soul</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
</head>
<body>
  <div class="grain"></div>

  <header class="site-header">
    <a href="{{ '/' | url }}" class="site-title">Expressions of an Analog Soul</a>
    <p class="site-tagline">verse from a quieter frequency</p>
  </header>

  <main class="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <span class="footer-divider"></span>
    <p>
      <span class="footer-copy">&copy; {{ "" | buildYear }} Expressions of an Analog Soul</span>
      <span class="footer-dot">&middot;</span>
      <span class="footer-location">Earth</span>
    </p>
  </footer>
  <!-- #region agent log -->
  <script>
  (function(){
    var links = Array.from(document.querySelectorAll('a[href]')).map(function(a){return a.getAttribute('href');});
    fetch('http://127.0.0.1:7324/ingest/6a389be5-5190-43d6-9c95-f0f8e7592ec6',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'682b5a'},body:JSON.stringify({sessionId:'682b5a',runId:'post-fix',hypothesisId:'H-A',location:'base.njk:body',message:'post-fix — url and link hrefs',data:{pageHref:window.location.href,pathname:window.location.pathname,allLinkHrefs:links},timestamp:Date.now()})}).catch(function(){});
  })();
  </script>
  <!-- #endregion -->
</body>
</html>
