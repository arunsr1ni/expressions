<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or 'A poetry blog — Expressions of an Analog Soul' }}" />
  <title>{% if title %}{{ title }} — {% endif %}Expressions of an Analog Soul</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  <link rel="alternate" type="application/atom+xml" title="Expressions of an Analog Soul" href="{{ '/feed.xml' | url }}" />
</head>
<body>
  <div class="grain"></div>

  <header class="site-header">
    <a href="{{ '/' | url }}" class="site-title">Expressions of an Analog Soul</a>
    <p class="site-tagline">verse from a quieter frequency</p>
  </header>

  <main class="main-content">
    {{ content | safe }}
  </main>

  <script src="{{ '/js/comments.js' | url }}" defer></script>

  <footer class="site-footer">
    <span class="footer-divider"></span>
    <p>
      <span class="footer-copy">&copy; {{ "" | buildYear }} Expressions of an Analog Soul</span>
      <span class="footer-dot">&middot;</span>
      <span class="footer-location">Earth</span>
      <span class="footer-dot">&middot;</span>
      <a href="{{ '/feed.xml' | url }}" class="footer-rss">RSS</a>
    </p>
  </footer>
</body>
</html>
