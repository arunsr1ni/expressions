---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Expressions of an Analog Soul</title>
  <subtitle>verse from a quieter frequency</subtitle>
  <link href="https://retrophile.blog/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="https://retrophile.blog/" rel="alternate" type="text/html"/>
  <id>https://retrophile.blog/</id>
  <updated>{{ collections.poems | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <author>
    <name>Expressions of an Analog Soul</name>
    <uri>https://retrophile.blog/</uri>
  </author>

  {%- for poem in collections.poems %}
  <entry>
    <title>{{ poem.data.title }}</title>
    <link href="{{ poem.url | absoluteUrl("https://retrophile.blog") }}" rel="alternate" type="text/html"/>
    <id>{{ poem.url | absoluteUrl("https://retrophile.blog") }}</id>
    <published>{{ poem.date | dateToRfc3339 }}</published>
    <updated>{{ poem.date | dateToRfc3339 }}</updated>
    {%- if poem.data.excerpt %}
    <summary>{{ poem.data.excerpt }}</summary>
    {%- endif %}
    <content type="html"><![CDATA[{{ poem.templateContent | safe }}]]></content>
  </entry>
  {%- endfor %}
</feed>
